[sub_resource type="GDScript" id="GDScript_42xju"]
script/source = "extends Label

func _process(delta: float) -> void:
	# 1. Включаем радар и ищем первый попавшийся узел с маячком \"Player\"
	var target = get_tree().get_first_node_in_group(\"Player\")
	
	# 2. Если радар кого-то нашел (target не равен пустоте)
	if target != null:
		# 3. Меняем текст
		text = \"HP: \" + str(target.health)
"

